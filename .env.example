# --- Data source ---
# "sample" uses the bundled fake inbox (data/sample_emails.json) — no setup needed.
# "gmail" pulls from a real Gmail account via OAuth — requires credentials.json (see README).
DATA_SOURCE=sample

# --- LLM provider ---
# "ollama" = free, runs locally, no API key needed (good for development)
# "openai" = paid, hosted, used for the live/cloud demo
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings (always local/free via HuggingFace) ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_PERSIST_DIR=./chroma_db
RETRIEVAL_K=4

# --- Gmail OAuth (only needed if DATA_SOURCE=gmail) ---
GMAIL_CREDENTIALS_PATH=./credentials.json
GMAIL_TOKEN_PATH=./token.json
GMAIL_MAX_RESULTS=50

# --- Weights & Biases (optional — leave blank to disable tracking) ---
WANDB_API_KEY=
WANDB_PROJECT=inbox-intelligence
